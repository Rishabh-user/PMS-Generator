# ── PMS Generator — Local Environment Configuration ──────────────
# Copy this file to `.env` and fill in real values. Keys marked
# "required" must be set for the server to run.
# The file is loaded by app/config.py via pydantic-settings.

# ── Anthropic (required) ──────────────────────────────────────────
# Claude API key used by /api/generate-pms and /api/regenerate-pms.
# Get one from https://console.anthropic.com/.
ANTHROPIC_API_KEY=your-api-key-here

# Optional — pin the Claude model used for PMS generation. Leave
# unset to use the default configured in app/config.py.
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Server ────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO

# ── PostgreSQL (optional but strongly recommended) ────────────────
# Backs the pms_cache + pms_agent_sessions tables. Without it,
# every request re-runs the AI and chat history won't persist.
# Local dev format: postgresql://user:pass@host:port/db
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/pms_generator

# ── External SPE Valvesheet backend (optional) ────────────────────
# When set, every newly-generated PMS is mirrored to this endpoint
# (POST on first generate, PUT on regenerate). Leave blank locally
# if you don't want your dev generations hitting the shared staging
# backend. Set it to point at your local valvesheet if you're
# testing the sync flow end-to-end.
#
# Staging:  https://spe-valvesheet-backend-staging.onrender.com/api/pms
# Local:    http://localhost:8000/api/pms  (or wherever the valvesheet
#                                           backend runs)
EXTERNAL_VALVESHEET_API_URL=https://spe-valvesheet-backend-staging.onrender.com/api/pms

# Optional auth header (e.g. "Bearer xxx" or "ApiKey xxx"). Only
# sent when non-empty.
EXTERNAL_VALVESHEET_AUTH=

# HTTP timeout for each valvesheet sync request in seconds.
EXTERNAL_VALVESHEET_TIMEOUT=20.0
